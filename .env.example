# Copiá a .env.local y completá con tus valores. No subir .env.local a git.
# En Vercel: Settings → Environment Variables — mismas claves. Production ✅

# Supabase — públicas (frontend). La ANON_KEY es segura: respeta RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — privadas (solo server: API routes). Mismo URL que arriba; SERVICE_ROLE bypass RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (solo server)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
