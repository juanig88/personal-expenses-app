# Copiá a .env.local y completá con tus valores. No subir .env.local a git.
# En Vercel: Settings → Environment Variables (las mismas claves).

# Supabase (frontend — sí son públicas)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (solo server / API routes — NUNCA con NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (solo server)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
